ff.p <- function(x,datess){as.numeric(mk.test(ts(x,start=as.numeric(substr(datess[1],1,4)),
end=as.numeric(substr(datess[length(datess)],1,4))))$p.value)}
ff.s <- function(x,datess){as.numeric(sens.slope(ts(x,start=as.numeric(substr(datess[1],1,4)),
end=as.numeric(substr(datess[length(datess)],1,4))))$estimates)}
ann.p = sfApply(ann, 2, FUN = ff.p, datess)
